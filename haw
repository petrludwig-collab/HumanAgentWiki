#!/usr/bin/env bash
# Convenience launcher: load .env (without overriding variables already set in
# the environment) and run the CLI inside the project's venv.
#   ./haw index | search "..." | serve | web | init-db | selftest
cd "$(dirname "$0")"
if [ -f .env ]; then
  while IFS= read -r line; do
    case "$line" in ''|\#*) continue ;; esac
    key=${line%%=*}
    [ -z "${!key+x}" ] && export "$line"   # only set if not already in the environment
  done < .env
fi
exec .venv/bin/python cli.py "$@"
