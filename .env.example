# Copy to .env and adjust. (python-dotenv not required — these are plain env vars.)

# Folder with your Markdown notes
NOTES_DIR=./notes

# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL=dbname=humanagentwiki user=humanagentwiki password=humanagentwiki host=localhost port=5432

# Embedding model — BGE-M3 is multilingual (great for Czech and 100+ languages).
# If you change the model, set EMBED_DIM to its dimension and re-create the schema.
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# MCP server bind
MCP_HOST=127.0.0.1
MCP_PORT=8802
